generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Ticket {
  id            Int      @id @default(autoincrement())
  titulo        String
  descripcion   String
  estado        String   @default("abierto")
  fechaCreacion DateTime @default(now())
}
